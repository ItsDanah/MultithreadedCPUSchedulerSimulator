import java.util.LinkedList;
import java.util.Queue; // interface representing FIFO structure

public class Main {

    public static void main(String[] args) {

        	Queue<PCB> jobQueue = new LinkedList<>(); // contains processes waiting to enter memory.
	        Queue<PCB> readyQueue = new LinkedList<>(); // contains processes ready for CPU execution.
	        Memory memory = new Memory(); // ram
	        SystemCall systemCalls = new SystemCall(memory); // provides operating system services, recieves memory object to allocate/deallocate memory.

	        JobReaderThread reader = new JobReaderThread(jobQueue, "job.txt"); // thread responsible for reading processes from the text file.
	        JobLoaderThread loader =new JobLoaderThread(jobQueue, readyQueue,systemCalls,reader); // Take jobs from jobQueue, Check memory availability, Move to readyQueue.

	        reader.start(); // start the thread in JobReaderThread class.
	        loader.start(); // start the thread in JobLoaderThread class.
        
    }
}
